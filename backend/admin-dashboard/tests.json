  "tests": [
    {"name": "OPTIONS", "method": "OPTIONS", "path": "/", "expectedStatus": 200},
    {"name": "No token - unauthorized", "method": "GET", "path": "/?section=overview", "expectedStatus": 401},
    {"name": "Invalid token - unauthorized", "method": "GET", "path": "/?section=overview", "headers": {"Authorization": "Bearer invalid.token.here"}, "expectedStatus": 401},
    {"name": "Wrong role (client token) - forbidden", "method": "GET", "path": "/?section=users", "expectedStatus": 401},
    {"name": "create_client - unauthorized", "method": "POST", "path": "/?section=create_client", "body": {}, "expectedStatus": 401}
  ]
}
